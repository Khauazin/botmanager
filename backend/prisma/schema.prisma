generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Usuários da plataforma (você e sua equipe) ────────────
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  clientId  String?  // Nulo para ADMIN, Preenchido para CLIENT/VIEWER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  alerts    Alert[]

  @@map("users")
}

// ─── Clientes contratantes ────────────────────────────────
model Client {
  id        String       @id @default(uuid())
  name      String
  email     String?
  phone     String?
  segment   String?
  plan      Plan         @default(BASIC)
  status    ClientStatus @default(ACTIVE)
  monthlyFee Float       @default(0)
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  bots      Bot[]
  alerts    Alert[]
  leads     Lead[]
  leadStages LeadStage[]
  appointments Appointment[]
  sales        Sale[]
  users        User[]

  @@map("clients")
}

// ─── Bots de cada cliente ─────────────────────────────────
model Bot {
  id              String    @id @default(uuid())
  clientId        String
  name            String
  channel         Channel   @default(WHATSAPP)
  status          BotStatus @default(OFFLINE)
  phoneNumber     String?   // Número do WhatsApp conectado
  messagesTotal   Int       @default(0)
  messagesToday   Int       @default(0)
  
  // Configurações de Inteligência Artificial
  aiProvider      AIProvider? // Ex: OPENAI, ANTHROPIC, DEEPSEEK
  aiModel         String?     // Ex: gpt-4o-mini
  aiApiKey        String?     // Token/Chave da API da IA
  aiSystemPrompt  String?     @db.Text
  aiTemperature   Float?      @default(0.7)

  lastActivityAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  alerts     Alert[]
  flows      Flow[]      // Fluxos deste bot
  variables  BotVariable[] // Variáveis que o cliente pode editar

  @@map("bots")
}

// Variáveis editáveis pelo cliente (Textos de saudação, horários, etc)
model BotVariable {
  id          String   @id @default(uuid())
  botId       String
  key         String   // ex: "GREETING_MESSAGE"
  value       String   // ex: "Olá! Como posso ajudar?"
  description String?  // Para exibir no painel do cliente ("Mensagem de boas vindas")
  type        VarType  @default(TEXT) // TEXT, NUMBER, BOOLEAN
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bot         Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, key])
  @@map("bot_variables")
}

// ─── Construtor de Fluxos (Builder) ───────────────────────
model Flow {
  id          String   @id @default(uuid())
  botId       String
  name        String
  isActive    Boolean  @default(false)
  triggerType TriggerType @default(KEYWORD) // KEYWORD, DEFAULT, ALWAYS
  triggerKeyword String? // Se for KEYWORD, qual a palavra chave?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bot         Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  nodes       Node[]
  edges       Edge[]

  @@map("flows")
}

// Blocos do construtor
model Node {
  id        String   @id // ID gerado pelo React Flow no frontend
  flowId    String
  type      NodeType // MESSAGE, QUESTION, CONDITION, ACTION, etc
  positionX Float
  positionY Float
  data      Json     // Dados específicos do nó (texto da msg, etc)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  flow      Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@map("nodes")
}

// Conexões entre blocos
model Edge {
  id           String   @id // ID gerado pelo React Flow
  flowId       String
  sourceNodeId String   // ID do Node origem
  targetNodeId String   // ID do Node destino
  sourceHandle String?  // Para condições (true/false, opções)
  createdAt    DateTime @default(now())

  flow         Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@map("edges")
}

// ─── CRM do Cliente ───────────────────────────────────────

// Fases do Funil (Kanban)
model LeadStage {
  id        String   @id @default(uuid())
  clientId  String
  name      String   // Ex: "Novo", "Em Atendimento", "Agendado", "Fechado"
  order     Int      // Ordem no Kanban
  color     String?  // Cor da coluna
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leads     Lead[]

  @@map("lead_stages")
}

model Lead {
  id          String   @id @default(uuid())
  clientId    String
  stageId     String?  // Pode não ter stage inicialmente
  name        String
  phone       String?
  email       String?
  value       Float?   // Valor potencial do lead
  notes       String?
  lastContact DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  stage       LeadStage? @relation(fields: [stageId], references: [id])
  messages    Message[]  // Histórico de conversa
  appointments Appointment[]
  sales        Sale[]

  @@map("leads")
}

// Histórico de mensagens do Inbox
model Message {
  id        String   @id @default(uuid())
  leadId    String
  content   String
  fromBot   Boolean  @default(false) // true = enviada pelo bot/cliente, false = recebida do lead
  createdAt DateTime @default(now())

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ─── Agenda e Agendamentos ─────────────────────────────────
model Appointment {
  id          String   @id @default(uuid())
  clientId    String
  leadId      String
  date        DateTime // Data e hora marcadas
  service     String?  // Serviço (ex: Corte de Cabelo, Consulta Odontológica)
  price       Float?   // Preço estimado/confirmado
  status      AppointmentStatus @default(PENDING)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("appointments")
}

// ─── Financeiro / Vendas ─────────────────────────────────
model Sale {
  id            String   @id @default(uuid())
  clientId      String
  leadId        String?
  amount        Float    // Valor da venda
  paymentMethod String?  // PIX, Cartão, Dinheiro
  status        SaleStatus @default(COMPLETED)
  description   String?
  date          DateTime @default(now()) // Data em que a venda ocorreu
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead          Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@map("sales")
}

// ─── Alertas ─────────────────────────────
model Alert {
  id        String      @id @default(uuid())
  botId     String
  clientId  String
  userId    String?
  severity  Severity    @default(ERROR)
  title     String
  message   String
  status    AlertStatus @default(OPEN)
  resolvedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  bot    Bot     @relation(fields: [botId], references: [id], onDelete: Cascade)
  client Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id])

  @@map("alerts")
}

// ─── Enums ────────────────────────────────────────────────
enum Role {
  ADMIN   // Você (Dono da plataforma)
  CLIENT  // O cliente (Clínica/Barbearia)
  VIEWER  // Funcionários do cliente
}

enum Plan {
  BASIC
  PRO
  PREMIUM
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BotStatus {
  ONLINE
  OFFLINE
  ERROR
}

enum Channel {
  WHATSAPP
  INSTAGRAM
  WEBSITE
  TELEGRAM
}

enum Severity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum AlertStatus {
  OPEN
  RESOLVED
  IGNORED
}

enum TriggerType {
  KEYWORD
  DEFAULT // Mensagem padrão para qualquer texto caso não caia em keyword
  ALWAYS  // Executa sempre
}

enum NodeType {
  MESSAGE
  QUESTION
  CONDITION
  DELAY
  HTTP_REQUEST
  UPDATE_LEAD
}

enum VarType {
  TEXT
  NUMBER
  BOOLEAN
}

enum AIProvider {
  OPENAI
  ANTHROPIC
  DEEPSEEK
  GEMINI
  CUSTOM
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}
