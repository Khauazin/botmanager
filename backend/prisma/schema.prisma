generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clientId  String?
  alerts    Alert[]
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("users")
}

model Client {
  id                   String                @id @default(uuid())
  name                 String
  email                String?
  phone                String?
  segment              String?
  plan                 Plan                  @default(BASIC)
  status               ClientStatus          @default(ACTIVE)
  monthlyFee           Float                 @default(0)
  notes                String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  alerts               Alert[]
  appointments         Appointment[]
  bots                 Bot[]
  leadStages           LeadStage[]
  leads                Lead[]
  sales                Sale[]
  users                User[]
  produtos             Produto[]
  lancamentosFinanceiros LancamentoFinanceiro[]
  categoriasFinanceiras CategoriaFinanceira[]

  @@map("clients")
}

model Bot {
  id             String        @id @default(uuid())
  clientId       String
  name           String
  channel        Channel       @default(WHATSAPP)
  status         BotStatus     @default(OFFLINE)
  phoneNumber    String?
  messagesTotal  Int           @default(0)
  messagesToday  Int           @default(0)
  lastActivityAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  aiModel        String?
  aiProvider     AIProvider?
  aiSystemPrompt String?
  aiTemperature  Float?        @default(0.7)
  aiApiKey       String?
  alerts         Alert[]
  variables      BotVariable[]
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  flows          Flow[]

  @@map("bots")
}

model BotVariable {
  id          String   @id @default(uuid())
  botId       String
  key         String
  value       String
  description String?
  type        VarType  @default(TEXT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bot         Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, key])
  @@map("bot_variables")
}

model Flow {
  id             String      @id @default(uuid())
  botId          String
  name           String
  isActive       Boolean     @default(false)
  triggerType    TriggerType @default(KEYWORD)
  triggerKeyword String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  edges          Edge[]
  bot            Bot         @relation(fields: [botId], references: [id], onDelete: Cascade)
  nodes          Node[]

  @@map("flows")
}

model Node {
  id        String   @id
  flowId    String
  type      NodeType
  positionX Float
  positionY Float
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  flow      Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@map("nodes")
}

model Edge {
  id           String   @id
  flowId       String
  sourceNodeId String
  targetNodeId String
  sourceHandle String?
  createdAt    DateTime @default(now())
  flow         Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@map("edges")
}

model LeadStage {
  id        String   @id @default(uuid())
  clientId  String
  name      String
  order     Int
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leads     Lead[]

  @@map("lead_stages")
}

model Lead {
  id                   String                 @id @default(uuid())
  clientId             String
  stageId              String?
  name                 String
  phone                String?
  email                String?
  value                Float?
  notes                String?
  lastContact          DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  tags                 String?
  priority             Priority               @default(MEDIUM)
  origin               String?
  appointments         Appointment[]
  history              LeadHistory[]
  client               Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  stage                LeadStage?             @relation(fields: [stageId], references: [id])
  messages             Message[]
  sales                Sale[]
  lancamentosFinanceiros LancamentoFinanceiro[]

  @@map("leads")
}

model LeadHistory {
  id        String   @id @default(uuid())
  leadId    String
  action    String
  fromStage String?
  toStage   String?
  notes     String?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_history")
}

model Message {
  id        String   @id @default(uuid())
  leadId    String
  content   String
  fromBot   Boolean  @default(false)
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Appointment {
  id            String            @id @default(uuid())
  clientId      String
  leadId        String?
  customerName  String
  customerPhone String?
  duration      Int               @default(30)
  origin        AppointmentOrigin @default(MANUAL)
  date          DateTime
  service       String?
  price         Float?
  status        AppointmentStatus @default(PENDING)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead   Lead?  @relation(fields: [leadId], references: [id])

  @@map("appointments")
}

model Sale {
  id                   String                @id @default(uuid())
  clientId             String
  leadId               String?
  amount               Float
  paymentMethod        String?
  status               SaleStatus            @default(COMPLETED)
  description          String?
  date                 DateTime              @default(now())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  client               Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead                 Lead?                 @relation(fields: [leadId], references: [id])
  lancamentosFinanceiros LancamentoFinanceiro[]
  movimentacoesEstoque MovimentacaoEstoque[]

  @@map("sales")
}

// ==========================================
// MÓDULO DE CATÁLOGO
// ==========================================

model Produto {
  id            String              @id @default(uuid())
  clientId      String
  nome          String
  descricao     String?
  tipo          TipoProduto         @default(FISICO)
  visibilidade  VisibilidadeProduto @default(ATIVO)
  estoqueMinimo Int?                @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  client    Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  variacoes VariacaoProduto[]

  @@map("produtos")
}

model VariacaoProduto {
  id           String   @id @default(uuid())
  produtoId    String
  nome         String // Ex: "Tamanho P", "Cor Azul"
  sku          String?  @unique
  preco        Float
  estoqueAtual Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  produto       Produto               @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  movimentacoes MovimentacaoEstoque[]

  @@map("variacoes_produto")
}

// ==========================================
// MÓDULO DE ESTOQUE
// ==========================================

model MovimentacaoEstoque {
  id         String           @id @default(uuid())
  variacaoId String
  tipo       TipoMovimentacao
  quantidade Int // Positivo para entrada, negativo para saída
  motivo     String?
  vendaId    String?
  data       DateTime         @default(now())

  variacao VariacaoProduto @relation(fields: [variacaoId], references: [id], onDelete: Cascade)
  venda    Sale?           @relation(fields: [vendaId], references: [id])

  @@map("movimentacoes_estoque")
}

// ==========================================
// MÓDULO FINANCEIRO
// ==========================================

model LancamentoFinanceiro {
  id             String           @id @default(uuid())
  clientId       String
  leadId         String?
  vendaId        String?
  categoriaId    String?
  descricao      String
  valor          Float
  tipo           TipoLancamento
  status         StatusFinanceiro @default(PENDENTE)
  dataVencimento DateTime
  dataPagamento  DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  client    Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead      Lead?                @relation(fields: [leadId], references: [id])
  venda     Sale?                @relation(fields: [vendaId], references: [id])
  categoria CategoriaFinanceira? @relation(fields: [categoriaId], references: [id])

  @@map("lancamentos_financeiros")
}

model CategoriaFinanceira {
  id       String         @id @default(uuid())
  clientId String
  nome     String
  tipo     TipoLancamento

  client      Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lancamentos LancamentoFinanceiro[]

  @@map("categorias_financeiras")
}

model Alert {
  id         String      @id @default(uuid())
  botId      String
  clientId   String
  userId     String?
  severity   Severity    @default(ERROR)
  title      String
  message    String
  status     AlertStatus @default(OPEN)
  resolvedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  bot        Bot         @relation(fields: [botId], references: [id], onDelete: Cascade)
  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user       User?       @relation(fields: [userId], references: [id])

  @@map("alerts")
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  ADMIN
  VIEWER
  CLIENT
}

enum Plan {
  BASIC
  PRO
  PREMIUM
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BotStatus {
  ONLINE
  OFFLINE
  ERROR
}

enum Channel {
  WHATSAPP
  INSTAGRAM
  WEBSITE
  TELEGRAM
}

enum Severity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum AlertStatus {
  OPEN
  RESOLVED
  IGNORED
}

enum TriggerType {
  KEYWORD
  DEFAULT
  ALWAYS
}

enum NodeType {
  MESSAGE
  QUESTION
  CONDITION
  DELAY
  HTTP_REQUEST
  UPDATE_LEAD
}

enum VarType {
  TEXT
  NUMBER
  BOOLEAN
}

enum AIProvider {
  OPENAI
  ANTHROPIC
  DEEPSEEK
  CUSTOM
  GEMINI
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum AppointmentOrigin {
  MANUAL
  AI
}

enum VisibilidadeProduto {
  ATIVO
  PAUSADO
  ARQUIVADO
}

enum TipoProduto {
  FISICO
  SERVICO
}

enum TipoMovimentacao {
  VENDA
  AJUSTE
  DEVOLUCAO
  COMPRA_FORNECEDOR
  RESERVA
}

enum StatusFinanceiro {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
}

enum TipoLancamento {
  RECEITA
  DESPESA
}
